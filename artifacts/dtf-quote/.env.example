# Backend URL without trailing slash. It can include /api or not.
VITE_API_URL="http://localhost:8080"

# Supabase Auth (OAuth + session handling in frontend)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Optional if the frontend will be served from a sub-path.
BASE_PATH="/"
