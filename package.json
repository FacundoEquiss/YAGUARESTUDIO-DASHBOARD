{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --workspace-concurrency=1 --filter \"!./artifacts/mockup-sandbox\" --if-present run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke:deploy": "pnpm --filter @workspace/scripts run smoke:deploy",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:reset-users": "pnpm --filter @workspace/scripts run db:reset-users",
    "db:seed-demo": "pnpm --filter @workspace/scripts run db:seed-demo",
    "db:reset-and-seed-demo": "pnpm --filter @workspace/scripts run db:reset-and-seed-demo",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --workspace-concurrency=1 --filter \"./artifacts/**\" --filter \"!./artifacts/mockup-sandbox\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "prettier": "^3.8.1",
    "tsx": "catalog:",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  }
}
