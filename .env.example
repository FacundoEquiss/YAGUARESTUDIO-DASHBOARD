# BASE DE DATOS
DATABASE_URL="postgresql://postgres:your_password@your_host:5432/postgres?sslmode=require"

# SEGURIDAD (Obligatorio en Prod)
JWT_SECRET="your_very_long_secure_random_string"

# CONFIGURACION BACKEND
PORT=8080
FRONTEND_URL="https://app.midominio.com"

# CREDENCIALES MASTER (Primer usuario de sistema admin)
MASTER_EMAIL="admin@midominio.com"
MASTER_PASSWORD="admin_secure_password"
MASTER_NAME="Admin Yaguar"

# MERCADO PAGO
MP_ACCESS_TOKEN="APP_USR-xxxx-xxxx-xxxx-xxxx"
MP_PUBLIC_KEY="APP_USR-xxxx-xxxx-xxxx-xxxx"
MP_WEBHOOK_SECRET="your_mercadopago_webhook_secret"
MP_STANDARD_PLAN_ID="your_standard_preapproval_plan_id"
MP_PREMIUM_PLAN_ID="your_premium_preapproval_plan_id"
